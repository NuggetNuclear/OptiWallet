# Connection string de Neon PostgreSQL
# Cópialo desde console.neon.tech → tu proyecto → Connection Details
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# ─── Sprint 2 (opcionales: sin definir, ambos servicios quedan desactivados) ──

# Sentry error tracking (US-ERR)
# Crea el proyecto en sentry.io → Settings → Client Keys (DSN)
# NEXT_PUBLIC_SENTRY_DSN="https://xxxxx@oXXXX.ingest.us.sentry.io/XXXX"

# Plausible analytics (US-ANA) — cookieless, sin banner de consentimiento.
# Script v2: pega el `src` del snippet que te da Plausible (Install → Script).
# Sin esta var el script no se inyecta. Si el host NO es plausible.io, agrégalo
# a script-src y connect-src en next.config.mjs.
# NEXT_PUBLIC_PLAUSIBLE_SRC="https://plausible.io/js/script.js"

# ─── Popularidad de comercios (cold-start del ranking) ───────────────────────

# Google Places API (New) — bootstrappea la popularidad de cada comercio cuando
# todavía no hay tráfico propio. En GCP: habilita "Places API (New)" y crea una
# API key (restringida a esa API). La usa scripts/compute-merchant-popularity.ts.
# GOOGLE_PLACES_API_KEY="AIza..."

# ─── Panel de administración ──────────────────────────────────────────────────

# Secreto para firmar sesiones de admin (HMAC-SHA256). Genera uno con:
#   openssl rand -hex 32
# Rotar este valor invalida todas las sesiones activas de admin de inmediato.
ADMIN_SESSION_SECRET="cambia-esto-a-un-secreto-real-de-32-bytes-hex"

# Clave dedicada para cifrar los secretos TOTP en la base de datos (AES-256-GCM).
# Genera una con: openssl rand -hex 32
# Si se omite, se deriva de ADMIN_SESSION_SECRET — pero en producción se
# RECOMIENDA una clave dedicada para que rotar la sesión no inutilice los
# secretos TOTP ya guardados. Rotar esta clave requiere re-enrolar el 2FA de
# todos los admins (o restaurar la clave anterior).
ADMIN_TOTP_ENC_KEY="cambia-esto-a-un-secreto-real-de-32-bytes-hex"

# ─── IA: resolver de comercios (central de operaciones) ──────────────────────
# Backend para el resolver de comercios (embeddings + categoría sugerida) en la
# revisión de promos scrapeadas. Agnóstico: cambias de nube a local con AI_PROVIDER.
# Si no se configura ninguno, la UI cae a matching por tokens (sin IA).

# AI_PROVIDER="gemini"   # gemini (default) | ollama | groq

# Gemini (Google AI Studio) — saca la key en https://aistudio.google.com/apikey
# GEMINI_API_KEY="AIza..."
# GEMINI_EMBED_MODEL="gemini-embedding-exp-03-07"  # verifica con: curl "https://generativelanguage.googleapis.com/v1beta/models?key=KEY" | grep embed
# GEMINI_GEN_MODEL="gemini-3.1-flash-lite"        # 500 RPD — mejor opción para generación JSON

# Ollama local (AI_PROVIDER=ollama) — requiere `ollama serve` corriendo y los
# modelos bajados: `ollama pull nomic-embed-text` y `ollama pull gemma2`.
# OLLAMA_URL="http://localhost:11434"
# OLLAMA_EMBED_MODEL="nomic-embed-text"
# OLLAMA_GEN_MODEL="gemma2"

# Groq (AI_PROVIDER=groq) — free tier generoso (~14 400 req/día con llama-3.1-8b-instant).
# No tiene modelos de embeddings → el ranking de comercios cae a matching por tokens.
# Solo afecta suggestCategory (elige categoría para comercios nuevos). Saca la key en:
# https://console.groq.com/keys
# GROQ_API_KEY="gsk_..."
# GROQ_GEN_MODEL="llama-3.1-8b-instant"   # opcional
