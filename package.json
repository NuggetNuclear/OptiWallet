{
  "name": "optiwallet",
  "version": "1.0.0-beta.2",
  "license": "GPL-3.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/stamp-sw-version.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "db:schema": "dotenv -e .env.local -- node scripts/apply-schema.ts",
    "db:seed": "dotenv -e .env.local -- node scripts/seed.ts",
    "db:gen-seed": "dotenv -e .env.local -- node scripts/gen-seed.ts",
    "db:migrate-tags": "dotenv -e .env.local -- node scripts/migrate-categories-to-tags.ts",
    "popularity:compute": "dotenv -e .env.local -- node scripts/compute-merchant-popularity.ts",
    "promotions:refresh": "dotenv -e .env.local -- node scripts/refresh-promos.ts",
    "test": "node --test \"lib/**/*.test.ts\" \"tests/**/*.test.ts\"",
    "test:watch": "node --test --watch \"lib/**/*.test.ts\" \"tests/**/*.test.ts\"",
    "test:coverage": "node --test --experimental-test-coverage \"lib/**/*.test.ts\" \"tests/**/*.test.ts\""
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@sentry/nextjs": "^10.57.0",
    "next": "^16.2.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.2.1",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.12",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "eslint": "$eslint",
    "postcss": "$postcss"
  }
}